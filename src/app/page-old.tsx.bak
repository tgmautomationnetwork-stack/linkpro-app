                </li>
                <li className="flex items-start gap-3">
                  <div className="mt-1 rounded-full bg-purple-100 p-1">
                    <Check className="w-4 h-4 text-purple-600" />
                  </div>
                  <span className="text-gray-700">Formation dédiée</span>
                </li>
              </ul>

              <Link href="/signup">
                <button className="w-full px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-600 text-white font-medium rounded-xl hover:shadow-lg hover:shadow-purple-500/25 transition-all">
                  Contacter les ventes
                </button>
              </Link>
            </div>
          </div>
        </div>
      </section>


      {/* Final CTA */}
      <section className="relative py-24 px-6 lg:px-8 overflow-hidden">
        <div className="absolute inset-0 bg-gradient-to-br from-purple-600 via-pink-600 to-purple-700" />
        <div className="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-20" />
        
        <div className="relative max-w-4xl mx-auto text-center">
          <h2 className="text-4xl sm:text-5xl font-bold text-white mb-6">
            Prêt à transformer vos ventes ?
          </h2>
          <p className="text-xl text-purple-100 mb-10 max-w-2xl mx-auto font-light">
            Rejoignez les centaines de vendeurs camerounais qui utilisent LinkPro pour professionnaliser leur business.
          </p>
          
          <div className="flex flex-col sm:flex-row items-center justify-center gap-4">
            <Link href="/signup">
              <button className="group px-8 py-4 bg-white text-purple-600 font-semibold rounded-2xl hover:shadow-2xl hover:scale-105 transition-all duration-300 flex items-center gap-3">
